@page "/courses/{Slug}"
@inject ApiService Api
@using HackZone.Web.Services
@using HackZone.Web.Models

<PageTitle>@(_course?.Title ?? "Kurs") - HackZone</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    @if (_loading)
    {
        <MudSkeleton Height="60px" Class="mb-4" />
        <MudSkeleton Height="200px" />
    }
    else if (_course is null)
    {
        <MudAlert Severity="Severity.Error">Kurs topilmadi.</MudAlert>
    }
    else
    {
        <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

        <MudGrid>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.h4" Class="hz-green mb-2">&gt; @_course.Title</MudText>
                <MudStack Row="true" Class="mb-4" Spacing="2">
                    <MudChip T="string" Color="GetDiffColor(_course.Difficulty)" Size="Size.Small">@_course.Difficulty</MudChip>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@_course.Category</MudChip>
                </MudStack>
                <MudText Class="hz-muted mb-6">@_course.Description</MudText>

                @if (_course.IsEnrolled && _course.ProgressPercent > 0)
                {
                    <MudProgressLinear Value="@_course.ProgressPercent" Color="Color.Success" Class="mb-4" />
                    <MudText Class="hz-muted mb-4">Progress: @_course.ProgressPercent%</MudText>
                }

                <MudText Typo="Typo.h6" Class="mb-3">Darslar</MudText>
                <MudList T="LessonListItem">
                    @foreach (var lesson in _course.Lessons.OrderBy(l => l.OrderIndex))
                    {
                        <MudListItem T="LessonListItem"
                                     @onclick="() => OpenLesson(lesson)"
                                     Class="hz-card mb-2" Style="cursor:pointer">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@(lesson.IsCompleted ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.PlayCircle)"
                                             Color="@(lesson.IsCompleted ? Color.Success : Color.Default)" />
                                    <MudText>@lesson.OrderIndex. @lesson.Title</MudText>
                                </MudStack>
                                <MudText Class="hz-muted">@lesson.DurationMinutes daq</MudText>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudCard Class="hz-card">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Class="mb-3">@_course.Lessons.Count ta dars</MudText>
                        @if (!_course.IsEnrolled)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       FullWidth="true" OnClick="Enroll" Disabled="_enrolling">
                                @(_enrolling ? "Yozilmoqda..." : "Kursga yozilish")
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       FullWidth="true" OnClick="() => OpenLesson(_course.Lessons.FirstOrDefault())">
                                Davom ettirish
                            </MudButton>
                        }
                        @if (_msg is not null)
                        {
                            <MudAlert Severity="@_msgSeverity" Class="mt-3">@_msg</MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        @if (_activeLesson is not null)
        {
            <MudDivider Class="my-6" />
            <MudText Typo="Typo.h5" Class="hz-green mb-4">@_activeLesson.Title</MudText>
            <MudPaper Class="hz-card pa-4 mb-4" Elevation="0">
                <div style="white-space: pre-wrap; font-family: monospace;">@_activeLesson.Content</div>
            </MudPaper>
            @if (_course.IsEnrolled && !_activeLesson.IsCompleted)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="CompleteLesson" Disabled="_completing">
                    @(_completing ? "Saqlanmoqda..." : "Darsni yakunlash")
                </MudButton>
            }
        }
    }
</MudContainer>

@code {
    [Parameter] public string Slug { get; set; } = "";
    [Inject] NavigationManager Nav { get; set; } = default!;

    private CourseDetailItem? _course;
    private LessonDetailItem? _activeLesson;
    private bool _loading = true;
    private bool _enrolling;
    private bool _completing;
    private string? _msg;
    private Severity _msgSeverity = Severity.Success;

    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _course = await Api.GetAsync<CourseDetailItem>($"api/courses/{Slug}");
        _loading = false;
        _breadcrumbs =
        [
            new("Bosh sahifa", "/"),
            new("Kurslar", "/courses"),
            new(_course?.Title ?? Slug, null, disabled: true)
        ];
    }

    private async Task OpenLesson(LessonListItem? lesson)
    {
        if (lesson is null) return;
        if (!(_course?.IsEnrolled ?? false))
        {
            _msg = "Darsni ko'rish uchun avval kursga yoziling.";
            _msgSeverity = Severity.Warning;
            return;
        }
        _activeLesson = await Api.GetAsync<LessonDetailItem>($"api/courses/{_course!.Id}/lessons/{lesson.Id}");
    }

    private async Task Enroll()
    {
        _enrolling = true;
        var (ok, err) = await Api.PostAsync($"api/courses/{_course!.Id}/enroll", new { });
        if (ok)
        {
            _msg = "Kursga muvaffaqiyatli yozildingiz!";
            _msgSeverity = Severity.Success;
            _course = await Api.GetAsync<CourseDetailItem>($"api/courses/{Slug}");
        }
        else
        {
            _msg = err ?? "Xatolik yuz berdi.";
            _msgSeverity = Severity.Error;
        }
        _enrolling = false;
    }

    private async Task CompleteLesson()
    {
        if (_activeLesson is null || _course is null) return;
        _completing = true;
        var (ok, err) = await Api.PostAsync($"api/courses/{_course.Id}/lessons/{_activeLesson.Id}/complete", new { });
        if (ok)
        {
            _msg = "Dars yakunlandi!";
            _msgSeverity = Severity.Success;
            _course = await Api.GetAsync<CourseDetailItem>($"api/courses/{Slug}");
            _activeLesson = _activeLesson with { IsCompleted = true };
        }
        _completing = false;
    }

    private Color GetDiffColor(string d) => d switch
    {
        "Easy" => Color.Success,
        "Medium" => Color.Warning,
        "Hard" => Color.Error,
        "Insane" => Color.Secondary,
        _ => Color.Default
    };
}
