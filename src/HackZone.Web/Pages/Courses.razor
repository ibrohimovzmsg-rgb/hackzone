@page "/courses"
@inject ApiService Api
@using HackZone.Web.Services

<PageTitle>Kurslar - HackZone</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="hz-green mb-6">&gt; Kurslar</MudText>

    @if (_loading)
    {
        <MudGrid>
            @for (int i = 0; i < 6; i++) {
                <MudItem xs="12" sm="6" md="4">
                    <MudSkeleton Height="200px" Class="hz-skeleton" />
                </MudItem>
            }
        </MudGrid>
    }
    else if (_courses is { Count: > 0 })
    {
        <MudGrid Spacing="4">
            @foreach (var c in _courses)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Class="hz-card" @onclick='() => Nav.NavigateTo($"/courses/{c.Slug}")'>
                        <MudCardContent>
                            <MudChip T="string" Color="GetDiffColor(c.Difficulty)" Size="Size.Small">@c.Difficulty</MudChip>
                            <MudText Typo="Typo.h6" Class="mt-2">@c.Title</MudText>
                            <MudText Class="hz-muted mt-1" Lines="2">@c.Description</MudText>
                            <MudStack Row="true" Class="mt-3" Justify="Justify.SpaceBetween">
                                <MudText Class="hz-muted"><MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" /> @c.LessonCount dars</MudText>
                                <MudText Class="hz-muted"><MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" /> @c.EnrollmentCount</MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudAlert Severity="Severity.Info">Hali kurslar qo'\''shilmagan.</MudAlert>
    }
</MudContainer>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;
    private List<CourseItem>? _courses;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _courses = await Api.GetAsync<List<CourseItem>>("api/courses");
        _loading = false;
    }

    private Color GetDiffColor(string d) => d switch
    {
        "Easy" => Color.Success,
        "Medium" => Color.Warning,
        "Hard" => Color.Error,
        "Insane" => Color.Secondary,
        _ => Color.Default
    };
}
